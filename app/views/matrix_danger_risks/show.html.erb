                                    <small><%= matrix_danger_item.updated_at.strftime("%F")  %></small>
                                </td>
                                <td class="text-center">
                                    <small><%= CompanyPosition.name_cargo(matrix_danger_item.type_cargo) %></small>
                                </td>
                                <td class="text-center">
