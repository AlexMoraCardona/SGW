                                </td>
                                <td class="text-center">
                                    <small><%= matrix_danger_item.clasification_danger_detail.name if matrix_danger_item.clasification_danger_detail_id.present? && matrix_danger_item.clasification_danger_detail_id.to_i > 0 %></small>
                                </td>
                                <% if matrix_danger_item.risk_level_interpretation.to_s == 'I No Aceptable'  %>
                                    <td style="border:1px solid black; text-align:center; background-color:#F03553"><small><%= matrix_danger_item.risk_level_interpretation %></small></td>
                                <% end  %>    
                                <% if matrix_danger_item.risk_level_interpretation.to_s == 'II No Aceptable'  %>
                                    <td style="border:1px solid black; text-align:center; background-color:#D98F3B"><small><%= matrix_danger_item.risk_level_interpretation %></small></td>
                                <% end  %>    
                                <% if matrix_danger_item.risk_level_interpretation.to_s == 'III Aceptable'  %>
                                    <td style="border:1px solid black; text-align:center; background-color:#F0E835"><small><%= matrix_danger_item.risk_level_interpretation %></small></td>
                                <% end  %>    
                                <% if matrix_danger_item.risk_level_interpretation.to_s == 'IV Aceptable'  %>
                                    <td style="border:1px solid black; text-align:center; background-color:#038018"><small><%= matrix_danger_item.risk_level_interpretation %></small></td>
                                <% end  %>    
                                <% if matrix_danger_item.danger_intervened == 0  %>
                                    <td style="text-align:center;"><small>NO</small></td>
                                <% else  %>    
                                    <td style="text-align:center;"><small>SI</small></td>
