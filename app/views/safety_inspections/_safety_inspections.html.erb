<% if @entity.present? %>
    <div class="container-fluid">
        <!-- Encabezado -->
        <div class="row align-items-center mb-4">
            <div class="col-12 col-lg-8">
                <h3 class="mb-1">
                    <%= @entity.business_name %>
                </h3>
                <small class="text-muted">
                    NIT:
                    <%= EvaluationRuleDetail.miles(@entity.identification_number) if @entity.identification_number.present? %>
                    <% if @entity.verification_digit.present? %>
                        -<%= @entity.verification_digit %>
                    <% end %>
                </small>
            </div>
            <div class="col-12 col-lg-4 text-lg-end mt-3 mt-lg-0">
                <%= link_to t('common.create_safety_inspection'), new_safety_inspection_path(entity_id: @entity.id), class: "btn btn-primary" %>
            </div>
        </div>
        <% if @safety_inspections.present? %>
            <!-- ========================= -->
            <!-- TABLA PARA PC -->
            <!-- ========================= -->
            <div class="d-none d-lg-block">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center">Formato de inspección de seguridad del:</th>
                                <th class="text-center">Lugar de la inspección:</th>
                                <th class="text-center">Área de trabajo:</th>
                                <th class="text-center"><%= t('.user_responsible') %></th>
                                <th class="text-center">Firma</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% @safety_inspections.each do |safety_inspection| %>
                                <tr>
                                    <td class="text-center">
                                        <%= safety_inspection.date_inspection %>
                                    </td>
                                    <td class="text-center">
                                        <%= safety_inspection.place_inspection %>
                                    </td>
                                    <td class="text-center">
                                        <%= safety_inspection.area_inspection %>
                                    </td>
                                    <td class="text-center">
                                        <%= safety_inspection.name_user(safety_inspection.user_responsible) %>
                                    </td>
                                    <td class="text-center">
                                        <% if safety_inspection.firm_responsible.to_i == 0 %>
                                            <%= link_to t('common.firmar'), firmar_responsable_inspeccion_path(safety_inspection.id, 2), class: 'btn btn-warning btn-sm' %>
                                        <% else %>
                                            <%= safety_inspection.date_firm_responsible %>
                                        <% end %>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <%= link_to "Ver situación o condición", situacion_condicion_path(safety_inspection.id), class:"btn btn-primary btn-sm me-2" %>
                                            <%= link_to t('common.show_safety_inspection'), safety_inspection_path(safety_inspection.id), class:"btn btn-info btn-sm me-2" %>
                                            <%= link_to t('common.edit'), edit_safety_inspection_path(safety_inspection.id), class:"btn btn-warning btn-sm me-2" %>
                                            <%= link_to "Ver informe", ver_informe_inspeccion_path(safety_inspection.id), class:"btn btn-info btn-sm me-2" %>
                                            <%= link_to "Ver informe PDF", pdf_informe_inspeccion_path(safety_inspection.id, format: 'pdf'), class:"btn btn-success btn-sm me-2" %>
                                        </div>
                                    </td>
                                </tr>
                            <% end %>
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- ========================= -->
            <!-- VERSION CELULAR -->
            <!-- ========================= -->
            <div class="d-lg-none">
                <% @safety_inspections.each do |safety_inspection| %>
                    <div class="card shadow-sm mb-3">
                        <div class="card-body">
                            <h5 class="card-title">
                                <%= safety_inspection.area_inspection %>
                            </h5>
                            <p class="mb-1">
                                <strong>Fecha:</strong>
                                <%= safety_inspection.date_inspection %>
                            </p>
                            <p class="mb-1">
                                <strong>Responsable:</strong>
                                <%= safety_inspection.name_user(safety_inspection.user_responsible) %>
                            </p>
                            <p class="mb-3">
                                <strong>Firma:</strong>
                                <% if safety_inspection.firm_responsible.to_i == 0 %>
                                    <%= link_to t('common.firmar'), firmar_responsable_inspeccion_path(safety_inspection.id, 2), class: 'btn btn-warning btn-sm' %>
                                <% else %>
                                    <%= safety_inspection.date_firm_responsible %>
                                <% end %>
                            </p>
                            <div class="d-grid gap-2">
                                    <%= link_to "Ver situación o condición", situacion_condicion_path(safety_inspection.id), class:"btn btn-primary btn-sm me-2" %>
                                    <%= link_to t('common.show_safety_inspection'), safety_inspection_path(safety_inspection.id), class:"btn btn-info btn-sm me-2" %>
                                    <%= link_to t('common.edit'), edit_safety_inspection_path(safety_inspection.id), class:"btn btn-warning btn-sm me-2" %>
                                    <%= link_to "Ver informe", ver_informe_inspeccion_path(safety_inspection.id), class:"btn btn-info btn-sm me-2" %>
                                    <%= link_to "Ver informe PDF", pdf_informe_inspeccion_path(safety_inspection.id, format: 'pdf'), class:"btn btn-success btn-sm me-2" %>
                            </div>
                        </div>
                    </div>
                <% end %>
            </div>
        <% end %>
    </div>
    <%= link_to "Retornar", request.referer || root_path, class: "btn btn-secondary" %>
<% end %>

