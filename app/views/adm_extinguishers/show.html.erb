<div class="container-fluid py-3">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap">
            <a class="navbar-brand mb-2 mb-md-0" href="/">
                <%= image_tag 'LogoConesst202305232.png', class: "img-fluid", style: "max-height:100px;" %>
            </a>
            <div>
                <%= link_to adm_extinguishers_path(entity_id: @adm_extinguisher.entity_id), class: "btn btn-secondary" do %>
                    Retornar
                <% end if @adm_extinguisher.present? %>
            </div>
        </div>
    </div>
    <div class="card shadow-sm">
        <div class="card-body">
            <%= render 'encabezado' %>
            <hr>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="border rounded p-2 h-100">
                        <strong>Fecha:</strong>
                        <%= @adm_extinguisher.date_creation if @adm_extinguisher.present? %>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="border rounded p-2 h-100">
                        <strong>Área:</strong>
                        <%= @adm_extinguisher.area if @adm_extinguisher.present? %>
                    </div>
                </div>
          </div>
          <div class="table-responsive">
                <table class="table table-bordered table-sm align-middle text-center">
                    <thead class="table-light">
                        <tr>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Número
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Tipo, Clase
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Capacidad
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Anillo Verificación
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Manómetro
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Pasador Seguridad
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Manija Descarga
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Válvula
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Manguera
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Boquilla
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Cuerpo Cilíndrico
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                              Instrucciones
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Soporte
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                               Señalización
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Ubicación
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Área de ubicación
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Próxima recarga
                            </th>
                            <th style="writing-mode: vertical-rl; transform: rotate(180deg); min-width:45px;">
                                Observaciones
                            </th>
                            <th style="min-width:45px;">
                                Acciones
                            </th>
                        </tr>    
                    </thead>
                    <tbody>
                        <% if @extinguishers.present? %>
                            <% @extinguishers.each do |extinguishers| %>
                                <tr>
                                    <td class="text-center">
                                        <small><%= extinguishers.nro %></small>
                                    </td>
                                    <td>
                                        <small><%= Extinguisher.label_type(extinguishers.type_extinguisher) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= extinguishers.ability %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.ring) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.pressure_gauge) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.barrette) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.handle) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.valve) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.hose) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.nozzle) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.cylindrical_body) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.decal) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.medium) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= Extinguisher.label(extinguishers.signaling) %></small>
                                    </td>
                                    <td>
                                        <small><%= Extinguisher.label(extinguishers.location) %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= extinguishers.area_location %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= extinguishers.date_vec_carga %></small>
                                    </td>
                                    <td class="text-center">
                                        <small><%= extinguishers.observation %></small>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-4 mt-3">
                                            <%= link_to t('common.adjunto'), extinguisher_adjunto_adm_extinguishers_path(extinguishers.id), class:"btn btn-primary btn-sm me-2 gap-3" %>
                                            <%= link_to "📷", extinguisher_foto_path(extinguishers.id), class:"btn btn-light btn-sm me-2 gap-3" %>
                                            <%= link_to "Editar", edit_extinguisher_path(extinguishers), class:"btn btn-warning btn-sm me-2 gap-3" %>
                                            <%= button_to "Eliminar", extinguishers, method: :delete, class: "btn btn-danger btn-sm gap-3", data: {turbo_confirm: "¿Está seguro de eliminar este registro? Esta acción no se puede deshacer." } %>                                            
                                        </div>
                                    </td>
                                </tr>
                            <% end %>
                        <% end %>
                    </tbody>
                </table>
          </div>
        </div> <!-- Fin table-responsive -->
        <% if @extinguishers.present? %>
            <div class="mt-5">
                <% @extinguishers.each do |extinguishers| %>
                    <% if extinguishers.extinguisher_fotos.attached? %>
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Archivos adjuntos extintor Nro:<%= extinguishers.nro %></h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-3" data-controller="previews">
                                    <% extinguishers.extinguisher_fotos.each do |file| %>
                                        <div class="col-12 col-md-6 col-lg-4">
                                            <% if file.image? %>
                                                <div class="card h-100">
                                                    <div class="card-body text-center">
                                                        <p class="small fw-bold">
                                                            <%= file.blob.filename %>
                                                        </p>
                                                        <%= image_tag file, data: { previews_target: "preview" }, class: "img-fluid rounded mb-3" %>
                                                        <%= link_to "Descargar archivo", rails_blob_path(file, disposition: "attachment"), class: "btn btn-success btn-sm" %>
                                                    </div>
                                                </div>
                                            <% elsif file.video? %>
                                                <div class="card h-100">
                                                    <div class="card-body text-center">
                                                        <p class="small fw-bold">
                                                            <%= file.blob.filename %>
                                                        </p>
                                                        <%= video_tag url_for(file), controls: true, class: "img-fluid mb-3" %>
                                                        <%= link_to "Descargar archivo", rails_blob_path(file, disposition: "attachment"), class: "btn btn-success btn-sm" %>
                                                    </div>
                                                </div>
                                            <% elsif file.audio? %>
                                                <div class="card h-100">
                                                    <div class="card-body text-center">
                                                        <p class="small fw-bold">
                                                            <%= file.blob.filename %>
                                                        </p>  
                                                        <%= audio_tag url_for(file), controls: true, class: "w-100 mb-3" %>
                                                        <%= link_to "Descargar archivo", rails_blob_path(file, disposition: "attachment"), class: "btn btn-success btn-sm" %>
                                                    </div>
                                                </div>
                                            <% else %>
                                                <div class="card h-100">
                                                    <div class="card-body text-center">
                                                        <p><%= link_to file.filename, url_for(file) %></p>
                                                        <%= link_to "Descargar archivo", rails_blob_path(file, disposition: "attachment"), class: "btn btn-success btn-sm" %>
                                                    </div>
                                                </div>
                                            <% end %>
                                        </div>
                                    <% end %>
                                </div>
                            </div>
                       </div>
                    <% end %>
                <% end %>
            </div>
        <% end %>
        <div class="mt-5 text-center">
            <h5 class="mb-4"><u><%= @adm_extinguisher.user.name if @adm_extinguisher.present? %></u></h5>
            <p class="mb-4">Nombre de quien realiza la inspección</p>
            <% if @adm_extinguisher.firm_user == 1 %>
                <% if @adm_extinguisher.user.firm.attached? %>
                    <% if @adm_extinguisher.user.firm.image? %>
                        <div class="mb-3">
                            <strong>Firma</strong>
                            <br>
                            <%= image_tag @adm_extinguisher.user.firm, class: "firma img-fluid" %>
                        </div>
                    <% end %>
                <% end %>
                <p><strong>Cargo:</strong><%= @adm_extinguisher.post if @adm_extinguisher.present? %></p>
            <% else %>
                <p>Firma:________________________________</p>
                <p><strong>Cargo:</strong><%= @adm_extinguisher.post if @adm_extinguisher.present? %></p>
            <% end %>
      </div>
    </div>
</div>
