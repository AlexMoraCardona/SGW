<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <!-- Encabezado -->
        <div class="row align-items-center g-3">
            <div class="col-12 col-md-3 text-center">
                <% if @safety_inspection.entity.logo.present? %>
                    <%= image_tag @safety_inspection.entity.logo, class: "img-fluid", style: "max-height:120px;" %>
                <% end %>
            </div>
            <div class="col-12 col-md-9">
                <div class="border rounded p-3 text-center mb-3">
                    <h5 class="mb-0">
                            <%= @safety_inspection.entity.business_name if @safety_inspection.present? %>
                    </h5>
                </div>
                <div class="border rounded p-3 text-center">
                    <h6 class="mb-0">
                        <%= @template.name if @template.present? %>
                    </h6>
                </div>
            </div>
        </div>
        <hr class="my-4">
        <!-- Información del documento -->
        <div class="row g-3">
            <div class="col-12 col-md-3">
                <div class="border rounded p-2 h-100">
                    <small class="text-muted">Código</small><br>
                    <strong>
                        <%= @template.reference if @template.present? %>
                    </strong>
                </div>
            </div>
            <div class="col-12 col-md-3">
                <div class="border rounded p-2 h-100">
                    <small class="text-muted">Versión</small><br>
                    <strong>
                        <%= @template.version if @template.present? %>
                    </strong>
                </div>
            </div>
            <div class="col-12 col-md-3">
                <div class="border rounded p-2 h-100">
                    <small class="text-muted">Fecha de elaboración</small><br>
                    <strong>
                        <%= @template.date if @template.present? %>
                    </strong>
                </div>
            </div>
            <div class="col-12 col-md-3">
                <div class="border rounded p-2 h-100">
                    <small class="text-muted">Fecha de actualización</small><br>
                    <strong>
                        <%= @template.date_updated if @template.present? %>
                    </strong>
                </div>
            </div>
        </div>
    </div>
</div>

