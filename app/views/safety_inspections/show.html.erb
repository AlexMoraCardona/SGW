<div align="left"; class="container col-12">
    <a class="navbar-brand" href="/">
        <%= image_tag 'LogoConesst202305232.png',:width => "100",  :height=>"100" %>
    </a>
</div>
<div><%= link_to "Retornar", request.referer || root_path, class: "btn btn-secondary" %></div>
<div class="container-fluid py-3">
    <div class="card shadow-sm border-0">
        <%= render 'encabezado' %>
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                Información de la Inspección
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <!-- Fecha -->
                <div class="col-12 col-lg-6">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-bold text-secondary mb-2">
                            Fecha de realización de la inspección
                        </div>
                        <div>
                            <%= @safety_inspection.date_inspection if @safety_inspection.present? %>
                        </div>
                    </div>
                </div>
                <!-- Lugar -->
                <div class="col-12 col-lg-6">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-bold text-secondary mb-2">
                            Lugar de la inspección
                        </div>
                        <div>
                            <%= @safety_inspection.place_inspection if @safety_inspection.present? %>
                        </div>
                    </div>
                </div>
                <!-- Área -->
                <div class="col-12">
                    <div class="border rounded p-3">
                        <div class="fw-bold text-secondary mb-2">
                            Área de trabajo a inspeccionar
                        </div>
                        <div>
                            <%= @safety_inspection.area_inspection if @safety_inspection.present? %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid py-3">
            <!-- Convenciones -->
            <div class="alert alert-info shadow-sm mb-4">
                <strong>SI:</strong> Cumple totalmente &nbsp;&nbsp;
                <strong>NO:</strong> No cumple &nbsp;&nbsp;
                <strong>PARCIAL:</strong> Cumple parcialmente (Especifique en observaciones cuáles no cumplen).
            </div>
            <!-- Título de la sección -->
            <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-info text-white text-center">
                <h5 class="mb-0">
                    GENERAL: PASILLOS, ESCALERAS Y ÁREAS COMUNES
                </h5>
            </div>
            <div class="card-header bg-secondary text-white text-center">
                <h6 class="mb-0">
                    CONDICIONES DE ORDEN Y ASEO
                </h6>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr class="text-center">
                            <th style="width:40%">
                                Situación o condición a inspeccionar
                            </th>
                            <th style="width:20%">
                                Cumplimiento
                            </th>
                            <th style="width:40%">
                                Observaciones
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if @safety_inspection_items.present? %>
                            <% @safety_inspection_items.each do |safety_inspection_item| %>
                                <% if safety_inspection_item.situation_condition.type_condition_inspection.id == 1 %>
                                    <tr>
                                        <td>
                                            <%= safety_inspection_item.situation_condition.name %>
                                        </td>
                                        <td class="text-center">
                                            <% case safety_inspection_item.state_compliance %>
                                                <% when 0 %>
                                                    <span class="badge bg-secondary">N/A</span>
                                            <% when 1 %>
                                                <span class="badge bg-success">SI</span>
                                            <% when 2 %>
                                                <span class="badge bg-danger">NO</span>
                                            <% when 3 %>
                                                <span class="badge bg-warning text-dark">PARCIAL</span>
                                            <% else %>
                                                <span class="badge bg-light text-dark border">SIN DEFINIR</span>
                                            <% end %>
                                        </td>
                                        <td>
                                            <% if safety_inspection_item.observation.present? %>
                                                <%= safety_inspection_item.observation %>
                                            <% else %>
                                                <span class="text-muted">Sin observaciones</span>
                                            <% end %>
                                        </td>
                                    </tr>
                                <% end %>
                            <% end %>
                        <% else %>
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    No existen registros para mostrar.
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
