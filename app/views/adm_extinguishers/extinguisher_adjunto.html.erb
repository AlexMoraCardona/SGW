<div class="container col-11 card p-5">
        <% if @extinguisher.present? %>
            <div class="mt-5">
                    <% if @extinguisher.extinguisher_fotos.attached? %>
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Archivos adjuntos extintor Nro:<%= @extinguisher.nro %></h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-3" data-controller="previews">
                                    <% @extinguisher.extinguisher_fotos.each do |file| %>
                                        <div class="col-12 col-md-6 col-lg-4">
                                            <% if file.image? %>
                                                <div class="card h-100">
                                                    <div class="card-body text-center">
                                                        <p class="small fw-bold">
                                                            <%= file.blob.filename %>
                                                        </p>
                                                        <%= image_tag file, data: { previews_target: "preview" }, class: "img-fluid rounded mb-3" %>
                                                        <%= link_to "Descargar archivo", rails_blob_path(file, disposition: "attachment"), class: "btn btn-success btn-sm" %>
                                                        <%= link_to "Borrar Archivo", purge_attachment_path(file), data: { 'turbo-method': :delete, 'turbo-confirm': '¿Está seguro de eliminar este registro? Esta acción no se puede deshacer.' }, class: 'btn btn-sm btn-danger' %> 
                                                    </div>
                                                </div>
                                            <% elsif file.video? %>
                                                <div class="card h-100">
                                                    <div class="card-body text-center">
                                                        <p class="small fw-bold">
                                                            <%= file.blob.filename %>
                                                        </p>
                                                        <%= video_tag url_for(file), controls: true, class: "img-fluid mb-3" %>
                                                        <%= link_to "Descargar archivo", rails_blob_path(file, disposition: "attachment"), class: "btn btn-success btn-sm" %>
                                                        <%= link_to "Borrar Archivo", purge_attachment_path(file), data: { 'turbo-method': :delete, 'turbo-confirm': '¿Está seguro de eliminar este registro? Esta acción no se puede deshacer.' }, class: 'btn btn-sm btn-danger' %> 
                                                    </div>
                                                </div>
                                            <% elsif file.audio? %>
                                                <div class="card h-100">
                                                    <div class="card-body text-center">
                                                        <p class="small fw-bold">
                                                            <%= file.blob.filename %>
                                                        </p>  
                                                        <%= audio_tag url_for(file), controls: true, class: "w-100 mb-3" %>
                                                        <%= link_to "Descargar archivo", rails_blob_path(file, disposition: "attachment"), class: "btn btn-success btn-sm" %>
                                                        <%= link_to "Borrar Archivo", purge_attachment_path(file), data: { 'turbo-method': :delete, 'turbo-confirm': '¿Está seguro de eliminar este registro? Esta acción no se puede deshacer.' }, class: 'btn btn-sm btn-danger' %> 
                                                    </div>
                                                </div>
                                            <% else %>
                                                <div class="card h-100">
                                                    <div class="card-body text-center">
                                                        <p><%= link_to file.filename, url_for(file) %></p>
                                                        <%= link_to "Descargar archivo", rails_blob_path(file, disposition: "attachment"), class: "btn btn-success btn-sm" %>
                                                        <%= link_to "Borrar Archivo", purge_attachment_path(file), data: { 'turbo-method': :delete, 'turbo-confirm': '¿Está seguro de eliminar este registro? Esta acción no se puede deshacer.' }, class: 'btn btn-sm btn-danger' %> 
                                                    </div>
                                                </div>
                                            <% end %>
                                        </div>
                                    <% end %>
                                </div>
                            </div>
                       </div>
                    <% end %>
            </div>
        <% end %>
</div>
 
<br>
<div class="container col-11 card p-5">
    <%= form_for @extinguisher do |f| %>
       <div class="row">
          <div class="form-group">
            <h5><%= f.label :"Adjuntar_Archivos:", style: "display: block" %></h5>
            <%= f.file_field :extinguisher_fotos, multiple: true %>

            <%= f.submit 'Subir Archivos', class: 'btn btn-sm btn-primary' %>
          </div> 
        </div>
    <% end %>
    <div><br></div>
    <div><br></div> 
    <%= link_to "Retornar", request.referer || root_path, class: "btn btn-secondary" %>

</div>  
<br>

