<div align="left"; class="container col-12">
    <a class="navbar-brand" href="/">
        <%= image_tag 'LogoConesst202305232.png',:width => "100",  :height=>"100" %>
    </a>
</div>
<div class="container col-11" 
    <br>
    <h2 class="display-5"><%= t('.title') %></h2>
    <hr>
</div>    
<div class="container col-11 card p-5">
    <br>
    <%= form_with model: @list do |form| %>
        <% @list.errors.full_messages.each do |error| %>
            <div class="alert alert-danger" role="alert">
                <%= error%> <%= alert %>
            </div>
        <% end %>  
        
        
        <div class="row g-2">
            <div class="col-sm-7">
                <%= form.label :state, style: "display: block" %>
                <%= form.select(:state, [['Cumple', 0], ['No cumple', 1], ['No aplica', 2]]) %>
            </div> 
        </div>  
        <br> 
        <div class="row g-2">
            <div class="col-sm-7">
                <%= form.label :observation, style: "display: block" %>
                <%= form.text_field :observation,  class: "form-control" %> 
            </div> 
        </div>  

        <%= form.hidden_field :entity_id, :value => Current.user.entity.to_i, class: "form-control" %>

        <br>    
        <button type="submit" class="btn btn-primary"><%=t('common.submit')%></button>

        <%= link_to '<button class="btn btn-primary" type="button">Retornar</button>'.html_safe, check_lists_path %>

    <% end %>
</div>        
 <br> 