<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                Editar Inspección de Seguridad
            </h4>
        </div>
        <div class="card-body">
            <%= form_with model: @safety_inspection_item do |form| %>
                <% if @safety_inspection_item.errors.any? %>
                    <div class="alert alert-danger">
                        <h6 class="mb-2">
                            Se encontraron los siguientes errores:
                        </h6>
                        <ul class="mb-0">
                            <% @safety_inspection_item.errors.full_messages.each do |error| %>
                                <li><%= error %></li>
                            <% end %>
                        </ul>
                    </div>
                <% end %>
                <!-- ==========================================
                     Estado de cumplimiento
                     ========================================== -->
                <div class="row mb-4">
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label fw-bold">
                            <%= t('.state_compliance') %>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-2"
                                data-bs-toggle="tooltip"
                                data-bs-html="true"
                                title="Seleccionar el cumplimiento de la situación o condición.">
                                <i class="bi bi-question-circle"></i>
                            </button>
                        </label>
                        <%= form.select :state_compliance,
                            [
                                ['N/A',0],
                                ['SI',1],
                                ['NO',2],
                                ['PARCIAL',3]
                            ],
                            {},
                            class:"form-select" %>
                    </div>
                </div>
                <!-- ==========================================
                     Observaciones
                     ========================================== -->
                <div class="mb-4">
                    <%= form.label :observation, class:"form-label fw-bold" %>
                    <%= form.text_area :observation, class:"form-control", rows:4 %>
                </div>
                <!-- ==========================================
                     Recomendaciones
                     ========================================== -->
                <div class="mb-4">
                    <%= form.label :recommendations, class:"form-label fw-bold" %>
                    <%= form.text_area :recommendations, class:"form-control", rows:4 %>
                </div>
                <!-- ==========================================
                     Intervención propuesta
                     ========================================== -->
                <div class="mb-4">
                    <%= form.label :proposed_intervention, class:"form-label fw-bold" %>
                    <%= form.text_area :proposed_intervention, class:"form-control", rows:4 %>
                </div>
                <!-- ==========================================
                     Botones
                     ========================================== -->
                <div class="d-flex flex-column flex-md-row justify-content-end gap-2">
                    <%= form.submit t('common.submit'), class:"btn btn-primary" %>
                    <%= link_to safety_inspections_path(entity_id: @safety_inspection_item.safety_inspection.entity_id), class:"btn btn-secondary" do %>
                        <i class="bi bi-arrow-left me-1"></i>
                        Retornar
                    <% end %>
                </div>
            <% end %>
        </div>
    </div>
    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                Adjuntar Evidencias
            </h5>
        </div>
        <div class="card-body">
            <%= form_with model: @safety_inspection_item, local: true do |f| %>
                <div class="row g-3 align-items-end">
                    <!-- Selección de archivos -->
                    <div class="col-12 col-lg-8">
                        <%= f.label :inspection_evidences, "Adjuntar archivos", class: "form-label fw-bold" %>
                        <%= f.file_field :inspection_evidences, multiple: true, class: "form-control" %>
                        <div class="form-text">
                            Puede seleccionar una o varias imágenes, videos, audios o documentos.
                        </div>
                    </div>
                    <!-- Botón -->
                    <div class="col-12 col-lg-4">
                        <div class="d-grid">
                            <%= f.submit "Subir archivos", class: "btn btn-success" %>
                        </div>
                    </div>
                </div>
            <% end %>
        </div>
    </div>
    <!-- ==========================================
         ARCHIVOS ADJUNTOS
         ========================================== -->
    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="bi bi-paperclip me-2"></i>
                Archivos adjuntos
            </h5>
        </div>
        <div class="card-body">
            <% if @safety_inspection_item.inspection_evidences.attached? %>
                <div class="row g-4" data-controller="previews">
                    <% @safety_inspection_item.inspection_evidences.each do |file| %>
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="card-body text-center">
                                        <!-- ===========================
                                             IMAGEN
                                            =========================== -->
                                        <% if file.image? %>
                                            <%= image_tag file, data: { previews_target: "preview" }, class: "img-fluid rounded shadow-sm mb-3", style: "max-height:300px; object-fit:contain;" %>
                                            <!-- ===========================
                                                 VIDEO
                                                 =========================== -->
                                        <% elsif file.video? %>
                                            <%= video_tag url_for(file), controls: true, class: "w-100 rounded shadow-sm mb-3" %>
                                            <!-- ===========================
                                                 AUDIO
                                                 =========================== -->
                                        <% elsif file.audio? %>
                                            <div class="mb-3">
                                                <i class="bi bi-file-music fs-1 text-primary"></i>
                                            </div>
                                            <%= audio_tag url_for(file), controls: true, class: "w-100 mb-3" %>
                                            <!-- ===========================
                                                 OTROS ARCHIVOS
                                                 =========================== -->
                                        <% else %>
                                            <div class="py-3">
                                                <i class="bi bi-file-earmark-text display-3 text-secondary"></i>
                                            </div>
                                            <h6 class="text-break mb-3">
                                                <%= file.filename %>
                                            </h6>
                                        <% end %>
                                        <!-- Nombre del archivo -->
                                        <% unless file.audio? || !file.image? && !file.video? %>
                                            <p class="small text-muted text-break">
                                                <%= file.filename %>
                                            </p>
                                        <% end %>
                                    </div>
                                    <div class="card-footer bg-white border-0">
                                        <div class="d-grid gap-2">
                                            <%= link_to rails_blob_path(file, disposition: :attachment),
                                                    class: "btn btn-success btn-sm" do %>
                                                    <i class="bi bi-download me-1"></i>
                                                    Descargar
                                            <% end %>
                                            
                                            <%= link_to purge_attachment_path(file), data: {turbo_method: :delete, turbo_confirm: "¿Está seguro de eliminar este registro? Esta acción no se puede deshacer." }, class: "btn btn-danger btn-sm" do %>
                                                    <i class="bi bi-trash me-1"></i>
                                                    Eliminar 
                                            <% end %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                    <% end %>
                </div>
            <% else %>
                <div class="text-center py-5">
                    <i class="bi bi-folder2-open display-1 text-secondary"></i>
                        <h5 class="mt-3 text-muted">
                            No existen archivos adjuntos
                        </h5>
                        <p class="text-muted mb-0">
                            Utilice el formulario superior para cargar evidencias.
                        </p>
                </div>
            <% end %>
        </div>
    </div>
</div>                                

