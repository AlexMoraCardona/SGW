<%= form_with(model: @extinguisher,
              url: extinguisher_foto_path(@extinguisher),
              method: :patch,
              local: true) do |f| %>

  <div class="card">

    <div class="card-header">
      <h3>Fotografía del extintor</h3>
    </div>

    <div class="card-body">

      <div id="camera-container" class="text-center">

        <video
          id="video"
          autoplay
          playsinline
          muted
          width="640"
          height="480"
          style="border:1px solid #999;border-radius:10px;">
        </video>

        <canvas
          id="canvas"
          style="display:none;">
        </canvas>

        <img
          id="preview"
          class="img-fluid"
          style="display:none;border:1px solid #999;border-radius:10px;">

      </div>

      <br>

      <%= hidden_field_tag :photo_data, nil, id: "photo_data" %>

      <div class="text-center">

        <button
          type="button"
          id="capture"
          class="btn btn-primary">

          📷 Tomar fotografía

        </button>

        <button
          type="button"
          id="retry"
          class="btn btn-warning"
          style="display:none;">

          🔄 Tomar nuevamente

        </button>

      </div>

    </div>

    <div class="card-footer text-center">

      <%= f.submit "Guardar",
            class: "btn btn-success" %>

      <%= link_to "Cancelar",
            adm_extinguishers_path,
            class: "btn btn-secondary" %>

    </div>

  </div>

<% end %>