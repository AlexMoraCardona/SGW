<div align="left"; class="container col-12">
    <a class="navbar-brand" href="/">
        <%= image_tag 'LogoConesst202305232.png',:width => "100",  :height=>"100" %>
    </a>
</div>
<div class="container col-11" 
    <br>
    <h2 class="display-5"><%= t('.title') %></h2>
    <hr>
</div>    
<div class="container col-xs-12 col-sm-12 col-md-10 col-lg-10 col-xl-10">
    <br>
    <%= form_with model: @adm_extinguisher do |form| %>
        <% @adm_extinguisher.errors.full_messages.each do |error| %>
            <div class="alert alert-danger" role="alert">
                <%= error%> <%= alert %>
            </div>
        <% end %>


        <div class="row g-3">
            <div class="col-sm-4">
                <button type="button" class="btn btn-sm btn-light" data-bs-toggle="tooltip" data-bs-html="true" title="Ingrese la fecha."><%= image_tag 'ayuda.png',:width => "25",  :height=>"25" %> Fecha:</button>
                <%= form.date_field :date_creation,  class: "form-control" %>
            </div>        
            <div class="col-sm-5">    
                <button type="button" class="btn btn-sm btn-light" data-bs-toggle="tooltip" data-bs-html="true" title="Ingrese la dependencia a inspeccionar."><%= image_tag 'ayuda.png',:width => "25",  :height=>"25" %> Dependencia a inspeccionar:</button>
                <%= form.text_field :area,  class: "form-control" %>
            </div>
        </div>


        <br>    
        <button type="submit" class="btn btn-sm btn-primary"><%=t('common.submit')%></button>
        <%= link_to '<button class="btn btn-sm btn-primary" type="button">Retornar</button>'.html_safe, :back %>
        <div><br></div>
    <% end %>
</div>        
<br>
