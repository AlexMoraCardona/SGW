<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        Firma del Usuario Responsable
                    </h4>
                </div>
                <div class="card-body">
                    <%= form_with model: @kit do |form| %>
                        <% if @kit.errors.any? %>
                            <% @kit.errors.full_messages.each do |error| %>
                                <div class="alert alert-danger">
                                    <%= error %>
                                </div>
                            <% end %>
                        <% end %>
                        <div class="row g-4">
                            <div class="col-12">
                                <label class="form-label fw-bold">
                                    Usuario Responsable
                                </label>
                                <div class="form-control bg-light">
                                    <%= @kit.user.name %>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold">
                                    Firma autorizada del Usuario Responsable
                                </label>
                                <div class="mt-2">
                                    <div class="form-check form-check-inline">
                                        <%= form.radio_button :firm_user, 0, class: "form-check-input", id: "firm_user_no" %>
                                        <%= form.label :firm_user, "No", value: 0, class: "form-check-label", for: "firm_user_no" %>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <%= form.radio_button :firm_user, 1, class: "form-check-input", id: "firm_user_si" %>
                                        <%= form.label :firm_user, "Sí", value: 1, class: "form-check-label", for: "firm_user_si" %>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12">
                                <%= form.label :post, class: "form-label fw-bold" %>
                                <%= form.text_field :post, class: "form-control" %>
                            </div>
                        </div>
                        <%= form.hidden_field :date_firm_user, value: Time.current %>
                        <div class="d-flex flex-column flex-md-row justify-content-end gap-2 mt-4">
                            <%= form.submit t('common.submit'), class: "btn btn-primary" %>
                            <%= link_to "Retornar", request.referer || root_path, class: "btn btn-secondary" %>
                        </div>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</div>
